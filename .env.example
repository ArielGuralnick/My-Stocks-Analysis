# Copy this file to ".env" and fill in your real values.
# Green API credentials (https://green-api.com)
GREEN_API_ID_INSTANCE=1101000000
GREEN_API_TOKEN_INSTANCE=your_api_token_here

# Your WhatsApp number in international format, digits only, no "+" or spaces.
# Example for Israel: 972501234567
WHATSAPP_PHONE_NUMBER=972501234567

# Anthropic API (https://console.anthropic.com)
# Required for the AI Fundamental Analysis step.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Optional — defaults to claude-sonnet-4-5 if omitted.
ANTHROPIC_MODEL=claude-sonnet-4-5

# TASE (Tel Aviv Stock Exchange) API — for Israeli securities in TASE_MAP.
# Register free at https://openapi.tase.co.il → generate an API key.
TASE_API_KEY=your_tase_api_key_here
