# Copy this file to ".env" and fill in your real values.
# Green API credentials (https://green-api.com)
GREEN_API_ID_INSTANCE=1101000000
GREEN_API_TOKEN_INSTANCE=your_api_token_here

# Your WhatsApp number in international format, digits only, no "+" or spaces.
# Example for Israel: 972501234567
WHATSAPP_PHONE_NUMBER=972501234567

# Anthropic API (https://console.anthropic.com)
# Required for the AI Fundamental Analysis step.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Optional — defaults to claude-sonnet-4-6 if omitted.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Cloud / no-Excel mode: comma-separated Yahoo Finance ticker symbols.
# Takes priority over EXCEL_FILE when set.
# TICKERS=AAPL,MSFT,TSLA,NVDA,AMZN,META,GOOG,AMD,ORCL

# Portfolio Excel file path (Excellence brokerage export).
# If omitted, auto-detects the most recent Excellence_*.xlsx in ~/Downloads.
EXCEL_FILE=C:\Users\YourName\Downloads\Excellence_040426.xlsx
# Optional — column name and header row in the Excel file.
# TICKER_COLUMN=שם נייר
# HEADER_ROW=9
